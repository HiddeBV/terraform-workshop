# Example terraform.tfvars for Sprint 4 - App Service
# Copy this file to terraform.tfvars and customize for your environment

# Dependencies from previous labs
network_resource_group_name   = "rg-terraform-network"    # From Sprint 2 output: resource_group_name
keyvault_resource_group_name  = "rg-terraform-keyvault"   # From Sprint 3 output: resource_group_name
vnet_name                     = "vnet-workshop"           # From Sprint 2 output: vnet_name
app_subnet_name               = "snet-app"                # From Sprint 2 output: app_subnet_name
key_vault_name                = "kv-workshop-xxxxxxxx"    # From Sprint 3 output: key_vault_name (with suffix)
managed_identity_name         = "id-workshop-app"        # From Sprint 3 output: managed_identity_name

# Basic Configuration
resource_group_name = "rg-terraform-app"
location           = "West Europe"

# App Service Configuration
app_service_plan_name = "asp-workshop"
app_service_plan_sku  = "B1"
app_service_name      = "app-workshop"

# Source Control Configuration (optional)
source_control_repo_url = "https://github.com/Azure-Samples/nodejs-docs-hello-world"
source_control_branch   = "master"

# Tags
tags = {
  Environment = "workshop"
  Sprint      = "04-app"
  ManagedBy   = "terraform"
  Owner       = "your-name"
}